# ==================================================
# MindEase Backend Mock - Environment Variables Template
# ==================================================
# INSTRUÇÕES:
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores sensíveis (JWT_SECRET, etc)
# 3. NUNCA commite o arquivo .env no Git
# ==================================================

# Server Configuration
PORT=3333
HOST=localhost
NODE_ENV=development

# JWT Configuration (⚠️ ALTERE EM PRODUÇÃO!)
# Generate strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:4201

# Logging (debug | info | warn | error)
LOG_LEVEL=info

# Database
DB_FILE=db.json
